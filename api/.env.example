# ── Server ──────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000   # ganti dengan domain portfolio saat live

# ── MongoDB Atlas ────────────────────────────────
# Daftar di https://cloud.mongodb.com → buat cluster gratis → copy connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/porto

# ── Cloudinary ───────────────────────────────────
# Daftar di https://cloudinary.com → Dashboard → copy credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Auth ─────────────────────────────────────────
# JWT secret: buat string random panjang (bisa pakai: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=ganti_dengan_string_random_panjang

# Admin password hash: jalankan perintah ini di terminal, copy hasilnya ke sini:
# node -e "require('bcryptjs').hash('PASSWORD_KAMU',10).then(console.log)"
ADMIN_PASSWORD_HASH=
